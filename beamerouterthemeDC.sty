% beamerouterthemeDC.sty - frame title, footline, optional slide logo

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerouterthemeDC}[2026/05/14 v1.1.0 DC Beamer Outer Theme]

\RequirePackage{tikz}

% -- Frame Title -----------------------------------------------------------
\setbeamertemplate{frametitle}{%
  \nointerlineskip%
  \begin{beamercolorbox}[wd=\paperwidth, ht=3.2ex, dp=1.2ex, leftskip=0.6cm, rightskip=0.6cm]{frametitle}%
    \usebeamerfont{frametitle}\insertframetitle%
    \ifx\insertframesubtitle\@empty\else
      \quad{\usebeamerfont{framesubtitle}\usebeamercolor[fg]{framesubtitle}\insertframesubtitle}%
    \fi
  \end{beamercolorbox}%
  \nointerlineskip%
  \begin{tikzpicture}[overlay]
    \draw[DCblue, line width=1.5pt] (-0.4cm,0) -- (\paperwidth,0);
  \end{tikzpicture}%
  \vskip 4pt%
}

% -- Footline -----------------------------------------------------------
\setbeamertemplate{footline}{%
  \leavevmode%

    \hbox{%
      \begin{beamercolorbox} [wd=.33\paperwidth,ht=2.8ex,dp=1.2ex,left,leftskip=.6cm]{footline}%
         \insertshortauthor
      \end{beamercolorbox}%
      \begin{beamercolorbox}[wd=.34\paperwidth,ht=2.8ex,dp=1.2ex,center]{footline}%
         \insertshorttitle
      \end{beamercolorbox}%
      \begin{beamercolorbox}[wd=.33\paperwidth,ht=2.8ex,dp=1.2ex,right,rightskip=.6cm]{footline}%
     \insertframenumber\,/\,\inserttotalframenumber
      \end{beamercolorbox}%
    }%
  % -- Optional logo on content slides (showlogo option) --
  \if@DCshowlogo
    \begin{tikzpicture}[overlay, remember picture]
      \ifx\@uulogoblackpath\@empty\else
        \node[anchor=north east, inner sep=0pt]
          at ([xshift=0.1cm, yshift=0.2cm]current page.north east)
          {\includegraphics[height=1.4cm]{\@uulogoblackpath}};
      \fi
    \end{tikzpicture}%
  \fi
}

% -- Thank-you / closing frame --------------------------------
\newcommand{\thankframe}[2]{%
  \begingroup
  \setbeamercolor{background canvas}{bg=DCblue}
  \begin{frame}[plain]
    \vfill
    \begin{center}
      \vspace{1cm}
      {\color{DCwhite}\LARGE\rmfamily\bfseries #1}%
      \ifstrempty{#2}{}{%
        \\[12pt]%
        {\color{DCwhite!35}\rule{2.2cm}{0.7pt}}\\[14pt]%
        {\color{DCwhite!65}\small\sffamily #2}%
      }%
      \vskip 30pt%
      \ifx\@uulogoblackpath\@empty\else
        \hskip 0pt \includegraphics[height=2cm]{\@uulogowhitepath}%
      \fi
    \end{center}
    \vfill
  \end{frame}
  \endgroup
}

\endinput
