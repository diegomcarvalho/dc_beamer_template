% beamerinnerthemeDC.sty - title page, blocks, items, special frames

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerinnerthemeDC}[2026/05/14 v1.1.0 DC Beamer Inner Theme]

\RequirePackage{tikz}
\usetikzlibrary{positioning}
\RequirePackage{calc}
\RequirePackage{setspace}
\RequirePackage{etoolbox}
\RequirePackage{graphicx}

% -- Internal: logo path storage (set by beamerthemeDC.sty) -----------
\newcommand{\@uulogopath}{}
\newcommand{\@uulogoblackpath}{}
\newcommand{\@uulogowhitepath}{}

% -- Conference author switch -----------------------------------------
% Enable conference-style multi-author formatting explicitly with:
%   \multiauthor
% Reset to single-author layout with:
%   \singleauthor
\newif\if@uumultiauthor
\@uumultiauthorfalse
\newcommand{\multiauthor}{\@uumultiauthortrue}
\newcommand{\singleauthor}{\@uumultiauthorfalse}

% -- Conference institute list ----------------------------------------
% Two ways to set institutes for multi-author title pages:
%
% Option A — \addinstitute (recommended, no manual formatting needed):
%   \addinstitute{1}{Dept.\ of ICS, Utrecht University}
%   \addinstitute{2}{Faculty of EEMCS, Delft University of Technology}
%   Call \clearinstitutes to reset between title pages.
%
% Option B — \confinstitute (manual, full control):
%   \confinstitute{%
%     {\scriptsize 1}\enspace Utrecht University \\[-1pt]
%     {\scriptsize 2}\enspace Delft University%
%   }
\newcommand{\@uuconfinstitute}{}
\newcommand{\confinstitute}[1]{\renewcommand{\@uuconfinstitute}{#1}}

\newif\if@uufirstinstitute
\@uufirstinstitutetrue

\newcommand{\addinstitute}[2]{%
  \if@uufirstinstitute
    \gappto\@uuconfinstitute{{\scriptsize #1}\enspace #2}%
    \global\@uufirstinstitutefalse
  \else
    \gappto\@uuconfinstitute{\\[-1pt]{\scriptsize #1}\enspace #2}%
  \fi
}

\newcommand{\clearinstitutes}{%
  \gdef\@uuconfinstitute{}%
  \global\@uufirstinstitutetrue
}

% -- Venue metadata ----------------------------------------------------
\newif\if@uuvenuepresent
\@uuvenuepresentfalse
\newcommand{\@uuvenue}{}
\newcommand{\venue}[1]{%
  \@uuvenuepresenttrue
  \renewcommand{\@uuvenue}{#1}%
}
\newcommand{\uutitlemeta}{%
  \if@uuvenuepresent
    \vskip 2pt%
    \@uuvenue
    \ifx\insertdate\@empty\else
      \enspace{\color{DCdarkgray}$\cdot$}\enspace\insertdate
    \fi
  \else
    \insertdate
  \fi
}

% -- Itemize -----------------------------------------------------------
\setbeamertemplate{itemize item}{\scriptsize\raise1.5pt\hbox{\color{DCblue}\vrule width 6pt height 6pt}}
\setbeamertemplate{itemize subitem}{\scriptsize\raise1.5pt\hbox{\color{DCorange}\vrule width 5pt height 5pt}}
\setbeamertemplate{itemize subsubitem}{\scriptsize\raise1.5pt\hbox{\color{DCbrown}\vrule width 4pt height 4pt}}

% -- Enumerate ---------------------------------------------------------
\setbeamertemplate{enumerate item}{%
  \tikz[baseline=(num.base)]{
    \node[fill=DCblue, text=DCwhite, font=\footnotesize\bfseries,
          minimum size=1.4em, inner sep=0pt] (num) {\insertenumlabel};
  }%
}
\setbeamertemplate{enumerate subitem}{%
  \tikz[baseline=(num.base)]{
    \node[fill=DClightgray, text=DCdarkblue, font=\footnotesize\bfseries,
          minimum size=1.2em, inner sep=0pt] (num) {\insertenumlabel};
  }%
}

% -- Blocks ------------------------------------------------------------
\setbeamertemplate{block begin}{%
  \vskip 6pt%
  \begin{beamercolorbox}[ht=2.6ex, dp=1ex, leftskip=0.6em, rightskip=0.6em]{block title}%
    \usebeamerfont{block title}\insertblocktitle%
  \end{beamercolorbox}%
  \nointerlineskip%
  \begin{beamercolorbox}[dp=1ex, leftskip=0.6em, rightskip=0.6em, vmode]{block body}%
    \vskip 4pt%
}
\setbeamertemplate{block end}{%
    \vskip 4pt%
  \end{beamercolorbox}%
  \vskip 4pt%
}
\setbeamertemplate{block alerted begin}{%
  \vskip 6pt%
  \begin{beamercolorbox}[ht=2.6ex, dp=1ex, leftskip=0.6em, rightskip=0.6em]{block title alerted}%
    \usebeamerfont{block title}\insertblocktitle%
  \end{beamercolorbox}%
  \nointerlineskip%
  \begin{beamercolorbox}[dp=1ex, leftskip=0.6em, rightskip=0.6em, vmode]{block body alerted}%
    \vskip 4pt%
}
\setbeamertemplate{block alerted end}{%
    \vskip 4pt%
  \end{beamercolorbox}%
  \vskip 4pt%
}
\setbeamertemplate{block example begin}{%
  \vskip 6pt%
  \begin{beamercolorbox}[ht=2.6ex, dp=1ex, leftskip=0.6em, rightskip=0.6em]{block title example}%
    \usebeamerfont{block title}\insertblocktitle%
  \end{beamercolorbox}%
  \nointerlineskip%
  \begin{beamercolorbox}[dp=1ex, leftskip=0.6em, rightskip=0.6em, vmode]{block body example}%
    \vskip 4pt%
}
\setbeamertemplate{block example end}{%
    \vskip 4pt%
  \end{beamercolorbox}%
  \vskip 4pt%
}

% ======================================================================
%  TITLE PAGE
% ======================================================================
% Author layout is now controlled explicitly:
%   - default: classic single-author layout
%   - \multiauthor: multi-author conference layout
%
% Venue/date line is controlled independently through \venue{...}.
\setbeamertemplate{title page}{%
  \begin{tikzpicture}[remember picture, overlay]
    % -- Yellow accent bar on left edge --
    \fill[DCblue]
      (current page.north west) rectangle
      ([xshift=8mm]current page.south west);
    % -- Warm gradient extending from the bar --
    \shade[left color=DCblue, right color=DCblue!0!white, opacity=0.28]
      ([xshift=8mm]current page.north west) rectangle
      ([xshift=0.40\paperwidth]current page.south west);
    % -- Radiating lines FROM the Sol logo centre --
    \coordinate (solcentre) at ([xshift=1.65cm, yshift=-1.45cm]current page.north west);
    \foreach \a in {-25,-17,-9,-1,7,15,23,31,39,47,55,63,71,79,87} {
      \draw[DCblue, opacity=0.2, line width=0.7pt]
        (solcentre) -- ++(\a:16cm);
    }
    % -- Logo top-left — positioned so Sol is at the ray origin --
    \ifx\@uulogopath\@empty\else
      \node[anchor=north west, inner sep=0pt]
        at ([xshift=0.4cm, yshift=-0.5cm]current page.north west)
        {\includegraphics[height=2cm]{\@uulogopath}};
    \fi
  \end{tikzpicture}%
  %
  \vskip 2.8cm%
  \begin{beamercolorbox}[leftskip=1.5cm, rightskip=1cm]{title}
    \usebeamerfont{title}\inserttitle\par%
    \ifdefempty{\insertsubtitle}{}{%
      \vskip 6pt%
      \usebeamerfont{subtitle}\usebeamercolor[fg]{subtitle}\insertsubtitle\par%
    }%
  \end{beamercolorbox}
  \vskip 8pt%
  {\color{DCblue}\hspace{1.5cm}\rule{3cm}{1.5pt}}%
  \vskip 12pt%
  %
  \if@uumultiauthor
    % --- Conference multi-author layout ---
    \begin{beamercolorbox}[leftskip=1.5cm, rightskip=1cm]{author}
      \usebeamerfont{author}%
      \def\and{\unskip,\enspace}%
      \def\inst##1{\textsuperscript{\footnotesize ##1}}%
      \insertauthor%
    \end{beamercolorbox}
    \vskip 5pt%
    \begin{beamercolorbox}[leftskip=1.5cm, rightskip=1cm]{institute}
      \usebeamerfont{institute}\footnotesize%
      \begin{tabular}[t]{@{}l@{}}
        \@uuconfinstitute
      \end{tabular}%
    \end{beamercolorbox}
    \vskip 3pt%
    \begin{beamercolorbox}[leftskip=1.5cm, rightskip=1cm]{date}
      \usebeamerfont{date}\uutitlemeta%
    \end{beamercolorbox}
  \else
    % --- Classic single-author layout ---
    \begin{beamercolorbox}[leftskip=1.5cm, rightskip=1cm]{author}
      \usebeamerfont{author}\insertauthor%
    \end{beamercolorbox}
    \vskip 4pt%
    \begin{beamercolorbox}[leftskip=1.5cm, rightskip=1cm]{institute}
      \usebeamerfont{institute}\insertinstitute%
    \end{beamercolorbox}
    \vskip 4pt%
    \begin{beamercolorbox}[leftskip=1.5cm, rightskip=1cm]{date}
      \usebeamerfont{date}\uutitlemeta%
    \end{beamercolorbox}
  \fi
}

% ======================================
%  SECTION PAGE
% ======================================
% Image for the *next* section divider (optional). Reset automatically
% after use, so subsequent \section{...} calls revert to the yellow style.
\newcommand{\@uusectionimage}{}
\newcommand{\sectionimage}[1]{\renewcommand{\@uusectionimage}{#1}}

\if@DCnosection\else
\AtBeginSection[]{%
  \begingroup
  \ifdefempty{\@uusectionimage}{%
    \sectionframe{\insertsection}%
  }{%
    \sectionframe[\@uusectionimage]{\insertsection}%
  }%
  \gdef\@uusectionimage{}% reset
  \endgroup
}
\fi

% ======================================
%  MANUAL SECTION PAGE
% ======================================
% \sectionframe{Title}              — yellow background (default)
% \sectionframe[image path]{Title}  — image background, yellow title panel
\NewDocumentCommand{\sectionframe}{O{} m}{%
  \begingroup
  \ifstrempty{#1}{%
    \setbeamercolor{background canvas}{bg=DCblue}
    \begin{frame}[plain]
      \vfill
      \hspace{0.08\paperwidth}%
      {\color{DCwhite}\rule{4cm}{2pt}}\\[8pt]%
      \hspace{0.08\paperwidth}%
      {\color{DCwhite}\LARGE\rmfamily\bfseries #2}%
      \vfill
    \end{frame}
  }{%
    \setbeamertemplate{background canvas}{%
      \includegraphics[width=\paperwidth, height=\paperheight,
                       keepaspectratio=false]{#1}%
    }%
    \setbeamertemplate{footline}{}%
    \begin{frame}[plain]
      \begin{tikzpicture}[remember picture, overlay]
        \fill[DCblue]
          ([yshift= 0.22\paperheight]current page.west) rectangle
          ([xshift=0.48\paperwidth, yshift=-0.22\paperheight]current page.west);
        \node[anchor=west, text width=0.36\paperwidth, inner sep=0pt]
          at ([xshift=0.08\paperwidth]current page.west) {%
            {\color{DCwhite}\rule{4cm}{2pt}}\\[8pt]%
            {\color{DCwhite}\LARGE\rmfamily\bfseries #2}%
          };
      \end{tikzpicture}%
    \end{frame}
  }%
  \endgroup
}
% ======================================
%  STANDOUT FRAME
% ======================================
\newcommand{\standoutframe}[1]{%
  \begingroup
  \setbeamercolor{background canvas}{bg=DCblue}
  \begin{frame}[plain]
    \vfill
    \begin{center}
      {\color{DCwhite}\rule{3cm}{1.5pt}}\\[14pt]
      {\color{DCwhite}\LARGE\rmfamily\bfseries #1\par}%
      \vskip 14pt%
      {\color{DCwhite}\rule{3cm}{1.5pt}}%
    \end{center}
    \vfill
  \end{frame}
  \endgroup
}

% full-width image with margins

% Optional argument = margin, default 0.25cm
\newcommand{\fullbleedimage}[2][0.5cm]{%
  \begin{tikzpicture}[remember picture, overlay]
    \def\m{#1}%

    \begin{scope}
      \clip
        ([xshift=\m,yshift=-\m]current page.north west)
        rectangle
        ([xshift=-\m,yshift=\m]current page.south east);

      \node[inner sep=0pt] at (current page.center) {%
        \includegraphics[
          width=\paperwidth
        ]{#2}%
      };
    \end{scope}
  \end{tikzpicture}
}


% -- Table of contents styling -----------------------------------------
\setbeamertemplate{section in toc}{%
  \tikz[baseline=(num.base)]{
    \node[fill=DCblue, text=DCwhite, font=\footnotesize\bfseries,
          minimum size=1.4em, inner sep=0pt] (num) {\inserttocsectionnumber};
  }\hspace{0.5em}\inserttocsection\par
}
\setbeamertemplate{subsection in toc}{%
  \hspace{2em}{\color{DCorange}\rule{4pt}{4pt}}\hspace{0.5em}%
  {\small\inserttocsubsection}\par
}


% ======================================
%  BRAND CLOSING FRAME
% ======================================
% \uupayoff — DC logo + payoff composed side-by-side (used by closingframe).
\newcommand{\@uupayoff}{%
  {\rmfamily\fontseries{l}\color{DCwhite} \fontsize{12.5}{14}\selectfont Universidade Federal}\vspace*{-0.05cm}\\{\opensans\fontseries{l}\Large\itshape\color{DCwhite} Tecnológica}%
}
\newcommand{\uupayoff}[1]{\renewcommand{\@uupayoff}{#1}}

\newcommand{\uubrandmark}{%
  \begin{tikzpicture}
    \node[inner sep=0pt] (uulogo) at (-3.5cm,0)
      {\ifx\@uulogoblackpath\@empty\else
         \includegraphics[height=2.3cm]{\@uulogowhitepath}%
       \fi};
    \node[anchor=east, inner sep=10pt] (tagline) at ([xshift=-2.5cm]uulogo.east)
      {\begin{tabular}{@{}l@{}}\@uupayoff\end{tabular}};
    \path ([xshift=1.5cm]tagline.east);
  \end{tikzpicture}%
}

% \closingframe — yellow brand closing slide.
% Usage:
%   \closingframe                  — logo + payoff only (top of screenshot)
%   \closingframe[partner content] — same, with rule and partner area below
\newcommand{\closingframe}[1][]{%
  \begingroup
  \setbeamercolor{background canvas}{bg=DCblue}
  \begin{frame}[plain]
    \ifstrempty{#1}{%
      % Simple version – centred
      \vfill
      \begin{center}{\uubrandmark}\end{center}
      \vfill
    }{%
      % With partner-logo area below a rule
      \vskip 20pt%
      \begin{center}\uubrandmark\end{center}
      \vspace{-0.5cm}
      \begin{center}{\color{DCwhite}\rule{0.66\paperwidth}{0.4pt}}\end{center}
      \vskip 8pt%
      \begin{center}#1\end{center}
      \vfill
    }%
  \end{frame}
  \endgroup
}

\endinput
