% beamerthemeDC.sty — Utrecht University Beamer Theme
%
% Usage:  \usetheme{DC}
%
% Options:
%   nl            — use Dutch logo (Universiteit Utrecht)
%   showlogo      — show small DC logo on every content slide
%   nosectionpage — suppress automatic section divider slides
%
% Commands:
%   \standoutframe{Text}             — yellow emphasis slide
%   \thankframe{Title}{Contact}      — compact closing slide
%   \closingframe                    — brand closing slide (logo + tagline)
%   \closingframe[partner logos]     — brand closing slide with partner area
%   \imageframe{path}                — full-bleed image slide
%   \begin{blankframe}…\end{...}     — completely empty slide
%   \venue{Conference, City}         — enable conference title layout
%
% Logos are loaded automatically from logos/ based on the nl option.

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerthemeDC}[2026/05/14 v1.1.0 A Beamer Theme for Utrecht University]


% -- Options -----------------------------------------------------------
\newif\if@DCnosection\@DCnosectionfalse
\newif\if@DCnl\@DCnlfalse
\newif\if@DCshowlogo\@DCshowlogofalse

\DeclareOption{nosectionpage}{\@DCnosectiontrue}
\DeclareOption{nl}{\@DCnltrue}
\DeclareOption{showlogo}{\@DCshowlogotrue}
\ProcessOptions\relax

% -- Sub-themes ----------------------------------------------------------
\usecolortheme{DC}
\useinnertheme{DC}
\useoutertheme{DC}

% -- Code listings --------------------------------------------------------
\RequirePackage{listings}
\lstset{
  basicstyle=\ttfamily\footnotesize,
  keywordstyle=\bfseries\color{DCdarkblue},
  stringstyle=\color{DCgreen},
  commentstyle=\itshape\color{DCdarkgray},
  numberstyle=\tiny\color{DCdarkgray},
  backgroundcolor=\color{DClightgray},
  frame=none,
  numbers=left,
  numbersep=8pt,
  breaklines=true,
  showstringspaces=false,
  tabsize=2,
  xleftmargin=1.5em,
}

% -- bibliography -----------------------------------------------------------
\usepackage[
  backend=biber,
  style=numeric,
  sorting=none
]{biblatex}

\addbibresource{references.bib}

% -- Font setup -----------------------------------------------------------
\usepackage[T1]{fontenc}

\IfFileExists{merriweather.sty}{%
  \usepackage{merriweather}%
}{%
  \usepackage{palatino}%
}
\IfFileExists{opensans.sty}{%
  \usepackage[default]{opensans}%
}{}

\usefonttheme{professionalfonts}
\setbeamerfont{title}{family=\rmfamily, series=\bfseries, size=\LARGE}
\setbeamerfont{subtitle}{family=\sffamily, size=\normalsize}
\setbeamerfont{frametitle}{family=\rmfamily, series=\bfseries, size=\large}
\setbeamerfont{author}{family=\sffamily, size=\normalsize}
\setbeamerfont{institute}{family=\sffamily, size=\small}
\setbeamerfont{date}{family=\sffamily, size=\small}
\setbeamerfont{block title}{family=\sffamily, series=\bfseries, size=\normalsize}
\setbeamerfont{caption}{size=\small}
\setbeamerfont{footnote}{size=\footnotesize}

% -- Default logo paths (based on nl option) ---------------------------
\if@DCnl
  \renewcommand{\@uulogopath}{logos/vert_azul}
  \renewcommand{\@uulogowhitepath}{logos/vert_branco}
  \renewcommand{\@uulogoblackpath}{logos/vert_preto}
\else
  \renewcommand{\@uulogopath}{logos/vert_azul}
  \renewcommand{\@uulogowhitepath}{logos/vert_branco}
  \renewcommand{\@uulogoblackpath}{logos/vert_preto}
\fi

% -- Numbered captions (Table 1, Figure 1, …) ---------------------------
\setbeamertemplate{caption}[numbered]

% -- Bibliography font size ---------------------------------------------
\setbeamerfont{bibliography item}{size=\small}
\setbeamerfont{bibliography entry author}{size=\small}
\setbeamerfont{bibliography entry title}{size=\small}
\setbeamerfont{bibliography entry location}{size=\small}
\setbeamerfont{bibliography entry note}{size=\small}

% -- Navigation symbols off ---------------------------------------------
\setbeamertemplate{navigation symbols}{}

% -- Hyperref colors ----------------------------------------------------
\hypersetup{
  colorlinks=false,
  linkcolor=DCblue,
  urlcolor=DCwhite,
  citecolor=DCwhite,
}

\endinput
